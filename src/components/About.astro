---
interface Props {
  headline?: string;
  body?: string;
  body2?: string;
  body3?: string;
  images?: string[];
}

const {
  headline = 'I design and build things that are <em>intentional</em>, considered, and built to last.',
  body     = 'Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.',
  body2,
  body3,
  images   = ['/images/tntc.webp'],
} = Astro.props;
---

<section
  id="about"
  class="py-24 md:py-32 lg:py-40 px-6 md:px-14 lg:px-20"
  aria-label="About"
>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center">

    <!-- Left: text -->
    <div>
      <p
        class="about-text"
        set:html={headline}
      />
      <p
        class="mt-6 text-[0.95rem] leading-[1.85] tracking-[0.04em]"
        style="color: var(--muted);"
        set:html={body}
      />
      {body2 && (
        <p
          class="mt-4 text-[0.95rem] leading-[1.85] tracking-[0.04em]"
          style="color: var(--muted);"
          set:html={body2}
        />
      )}
      {body3 && (
        <p
          class="mt-4 text-[0.95rem] leading-[1.85] tracking-[0.04em]"
          style="color: var(--muted);"
          set:html={body3}
        />
      )}
    </div>

    <!-- Right: carousel -->
    <div class="about-carousel" aria-label="About images">

      <!-- Slides -->
      <div class="about-carousel-track">
        {images.map((src, i) => (
          <div
            class="about-carousel-slide"
            style={`opacity:${i === 0 ? 1 : 0}; z-index:${i === 0 ? 1 : 0};`}
          >
            <img
              src={src}
              alt={`TNTC Studio ${i + 1}`}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              class="w-full h-full object-cover"
            />
          </div>
        ))}
      </div>

      <!-- Controls (only shown when more than one image) -->
      {images.length > 1 && (
        <div class="about-carousel-controls">
          <!-- Dots -->
          <div class="about-carousel-dots">
            {images.map((_, i) => (
              <button
                class={`about-dot${i === 0 ? ' active' : ''}`}
                data-index={i}
                aria-label={`Go to image ${i + 1}`}
              />
            ))}
          </div>
        </div>
      )}

    </div>
  </div>
</section>

<style>
  .about-carousel {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .about-carousel-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .about-carousel-slide {
    position: absolute;
    inset: 0;
    transition: opacity 0.7s ease;
  }

  .about-carousel-controls {
    position: absolute;
    bottom: 1rem;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    z-index: 10;
  }

  .about-carousel-btn {
    background: rgba(30,30,30,0.5);
    border: 1px solid rgba(255,255,255,0.15);
    color: #fff;
    border-radius: 50%;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .about-carousel-btn:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #1E1E1E;
  }

  .about-carousel-dots {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .about-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    border: none;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
    padding: 0;
  }

  .about-dot.active {
    background: var(--accent);
    transform: scale(1.3);
  }
</style>

<script>
  function initAboutCarousel() {
    const slides = Array.from(document.querySelectorAll<HTMLElement>('.about-carousel-slide'));
    const dots   = Array.from(document.querySelectorAll<HTMLElement>('.about-dot'));

    if (slides.length <= 1) return;

    let current  = 0;
    let timer: ReturnType<typeof setInterval>;

    const INTERVAL = 4000;

    function goTo(index: number) {
      slides[current].style.opacity = '0';
      slides[current].style.zIndex  = '0';
      dots[current]?.classList.remove('active');

      current = (index + slides.length) % slides.length;

      slides[current].style.opacity = '1';
      slides[current].style.zIndex  = '1';
      dots[current]?.classList.add('active');
    }

    function startAuto() {
      timer = setInterval(() => goTo(current + 1), INTERVAL);
    }

    function resetAuto() {
      clearInterval(timer);
      startAuto();
    }

    dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); resetAuto(); }));

    startAuto();
  }

  document.addEventListener('astro:page-load', initAboutCarousel);
</script>
