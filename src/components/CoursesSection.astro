---
interface Props {
  headline?: string;
  body?:     string;
  body2?:    string;
  body3?:    string;
  images?:   string[];
}

const {
  headline = '',
  body     = '',
  body2,
  body3,
  images   = [],
} = Astro.props;
---

<section
  class="pt-0 pb-24 md:pb-32 lg:pb-40 px-6 md:px-14 lg:px-20"
  aria-label="Courses"
  id="teaching"
>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center">

    <!-- Left: text -->
    <div>
      {headline && (
        <p class="about-text" set:html={headline} />
      )}
      {body && (
        <p
          class="mt-6 text-[0.95rem] leading-[1.85] tracking-[0.04em]"
          style="color: var(--muted);"
          set:html={body}
        />
      )}
      {body2 && (
        <p
          class="mt-4 text-[0.95rem] leading-[1.85] tracking-[0.04em]"
          style="color: var(--muted);"
          set:html={body2}
        />
      )}
      {body3 && (
        <p
          class="mt-4 text-[0.95rem] leading-[1.85] tracking-[0.04em]"
          style="color: var(--muted);"
          set:html={body3}
        />
      )}
    </div>

    <!-- Right: image or carousel -->
    {images.length > 0 && (
      <div class="courses-carousel" aria-label="Courses images">
        <div class="courses-carousel-track">
          {images.map((src, i) => (
            <div
              class="courses-carousel-slide"
              style={`opacity:${i === 0 ? 1 : 0}; z-index:${i === 0 ? 1 : 0};`}
            >
              <img
                src={src}
                alt={`Courses ${i + 1}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
                class="w-full h-full object-cover"
              />
            </div>
          ))}
        </div>

        {images.length > 1 && (
          <div class="courses-carousel-controls">
            <div class="courses-carousel-dots">
              {images.map((_, i) => (
                <button
                  class={`courses-dot${i === 0 ? ' active' : ''}`}
                  data-index={i}
                  aria-label={`Go to image ${i + 1}`}
                />
              ))}
            </div>
          </div>
        )}
      </div>
    )}

  </div>
</section>

<style>
  .courses-carousel {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 10px;
  }
  .courses-carousel-track {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .courses-carousel-slide {
    position: absolute;
    inset: 0;
    transition: opacity 0.7s ease;
  }
  .courses-carousel-controls {
    position: absolute;
    bottom: 1rem;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }
  .courses-carousel-dots {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .courses-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    border: none;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
    padding: 0;
  }
  .courses-dot.active {
    background: var(--accent);
    transform: scale(1.3);
  }
</style>

<script>
  function initCoursesCarousel() {
    const slides = Array.from(document.querySelectorAll<HTMLElement>('.courses-carousel-slide'));
    const dots   = Array.from(document.querySelectorAll<HTMLElement>('.courses-dot'));
    if (slides.length <= 1) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval>;
    const INTERVAL = 4000;

    function goTo(index: number) {
      slides[current].style.opacity = '0';
      slides[current].style.zIndex  = '0';
      dots[current]?.classList.remove('active');
      current = (index + slides.length) % slides.length;
      slides[current].style.opacity = '1';
      slides[current].style.zIndex  = '1';
      dots[current]?.classList.add('active');
    }

    function startAuto() { timer = setInterval(() => goTo(current + 1), INTERVAL); }
    function resetAuto()  { clearInterval(timer); startAuto(); }

    dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); resetAuto(); }));
    startAuto();
  }

  document.addEventListener('astro:page-load', initCoursesCarousel);
</script>
