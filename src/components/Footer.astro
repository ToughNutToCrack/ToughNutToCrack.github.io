---
export interface FooterLink {
  label: string;
  href:  string;
}

interface Props {
  name?:  string;
  links?: FooterLink[];
}

const {
  name  = 'TNTC Studio',
  links = [
    { label: 'Email',    href: 'mailto:you@email.com'                      },
    { label: 'GitHub',   href: 'https://github.com/your-handle'            },
    { label: 'LinkedIn', href: 'https://linkedin.com/in/your-profile'      },
    { label: 'Twitter',  href: 'https://twitter.com/your-handle'           },
  ],
} = Astro.props;

const year = new Date().getFullYear();
---

<footer
  id="contact"
  class="border-t px-6 py-14 md:px-14 md:py-16 lg:px-20"
  style="border-color: var(--border);"
  aria-label="Footer"
>
  <div
    class="max-w-screen-lg mx-auto
           grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-10 sm:gap-6
           items-end"
  >
    <!-- Brand + copyright -->
    <div class="flex items-start gap-4">
      <img src="/images/logo.png" alt="TNTC Studio" class="h-10 w-auto mt-1" />
      <div>
      <p class="font-serif text-xl font-semibold tracking-[0.1em]">{name}</p>
      <p class="font-serif text-xs font-semibold tracking-[0.1em]">Matteo Baraldi P.IVA 03837730369</p>
      <p class="font-serif text-xs font-semibold tracking-[0.1em]">Erik Minarini P.IVA 03749901207</p>
      <p
        class="mt-2 text-[0.58rem] tracking-[0.18em] uppercase"
        style="color: var(--muted);"
      >
        &copy; {year} — All rights reserved
      </p>
      </div>
    </div>

    <!-- Links -->
    <nav
      class="flex flex-row sm:flex-col flex-wrap gap-x-6 gap-y-3 sm:text-right"
      aria-label="Footer links"
    >
      {links.map(({ label, href }) => {
        const isExternal = href.startsWith('http');
        return (
          <a
            href={href}
            class="footer-link"
            {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            style="color: var(--ink);"
          >
            {label}
          </a>
        );
      })}
    </nav>
  </div>
</footer>
