---
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';

const links = [
  { label: 'About',   href: isHome ? '#about'   : '/#about'   },
  { label: 'Portfolio',    href: isHome ? '#work'    : '/#work'    },
  { label: 'Video',    href: isHome ? '#content'    : '/#content'    },
  { label: 'Teaching',    href: isHome ? '#teaching'    : '/#teaching'    },
  { label: 'Contact', href: isHome ? '#contact' : '/#contact' },
];

const logoHref = isHome ? '#home' : '/';
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-5 md:px-10 md:py-6"
  style="background: rgba(30,30,30,0.82); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(195,195,195,0.1);"
  aria-label="Main navigation"
>
  <!-- Logo / Name -->
  <a
    href={logoHref}
    class="transition-opacity duration-200 hover:opacity-70"
    aria-label="Go to top"
  >
    <img src="/images/logoW.png" alt="TNTC Studio" class="h-10 w-auto" />
  </a>

  <!-- Desktop links -->
  <nav class="hidden sm:flex items-center gap-8" aria-label="Site sections">
    {links.map(({ label, href }) => (
      <a href={href} class="nav-link">{label}</a>
    ))}
    <a
      href="http://youtube.com/tntcproject"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="TNTC on YouTube"
      class="patreon-link"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
      </svg>
    </a>
    <a
      href="https://www.patreon.com/c/tntcproject"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Support us on Patreon"
      class="patreon-link"
    >
      <svg width="18" height="18" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" fill-rule="evenodd" clip-rule="evenodd" stroke-linejoin="round" stroke-miterlimit="2" fill="currentColor"><g transform="matrix(.47407 0 0 .47407 .383 .422)"><clipPath id="prefix__a"><path d="M0 0h1080v1080H0z"/></clipPath><g clip-path="url(#prefix__a)"><path d="M1033.05 324.45c-.19-137.9-107.59-250.92-233.6-291.7-156.48-50.64-362.86-43.3-512.28 27.2-181.1 85.46-237.99 272.66-240.11 459.36-1.74 153.5 13.58 557.79 241.62 560.67 169.44 2.15 194.67-216.18 273.07-321.33 55.78-74.81 127.6-95.94 216.01-117.82 151.95-37.61 255.51-157.53 255.29-316.38z" fill-rule="nonzero"/></g></g></svg>
    </a>
  </nav>

  <!-- Mobile hamburger -->
  <button
    id="menu-toggle"
    class="sm:hidden flex flex-col gap-[5px] p-2 -mr-2"
    aria-label="Toggle menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <span class="hamburger-line block w-5 h-px bg-[rgba(245,242,236,0.8)] transition-all duration-300 origin-center"></span>
    <span class="hamburger-line block w-5 h-px bg-[rgba(245,242,236,0.8)] transition-all duration-300"></span>
    <span class="hamburger-line block w-5 h-px bg-[rgba(245,242,236,0.8)] transition-all duration-300 origin-center"></span>
  </button>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 flex flex-col items-center justify-center gap-10
         bg-ink opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
  {links.map(({ label, href }) => (
    <a
      href={href}
      class="mobile-nav-link font-serif text-[#f5f2ec] text-4xl font-light italic tracking-wide
             opacity-0 translate-y-4 transition-all duration-300"
    >
      {label}
    </a>
  ))}

  <!-- Social icons -->
  <div class="mobile-nav-link flex items-center gap-6 opacity-0 translate-y-4 transition-all duration-300">
    <a
      href="http://youtube.com/tntcproject"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="TNTC on YouTube"
      class="patreon-link"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
      </svg>
    </a>
    <a
      href="https://www.patreon.com/c/tntcproject"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Support us on Patreon"
      class="patreon-link"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <path d="M14.82 2.41C11.53 2.41 8.85 5.1 8.85 8.39c0 3.28 2.68 5.95 5.97 5.95 3.28 0 5.95-2.67 5.95-5.95 0-3.29-2.67-5.98-5.95-5.98zM2.18 21.6h3.06V2.41H2.18V21.6z"/>
      </svg>
    </a>
  </div>
</div>

<script>
  function initNav() {
    const toggle = document.getElementById('menu-toggle');
    const menu   = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    const mLinks = menu.querySelectorAll<HTMLElement>('.mobile-nav-link');
    const hLines = toggle.querySelectorAll<HTMLElement>('.hamburger-line');

    let open = false;

    function openMenu() {
      open = true;
      toggle.setAttribute('aria-expanded', 'true');
      menu.setAttribute('aria-hidden', 'false');
      menu.classList.remove('opacity-0', 'pointer-events-none');
      menu.classList.add('opacity-100');
      hLines[0].style.transform = 'translateY(6px) rotate(45deg)';
      hLines[1].style.opacity   = '0';
      hLines[2].style.transform = 'translateY(-6px) rotate(-45deg)';
      mLinks.forEach((el, i) => {
        setTimeout(() => {
          el.style.opacity   = '1';
          el.style.transform = 'translateY(0)';
        }, 80 + i * 60);
      });
    }

    function closeMenu() {
      open = false;
      toggle.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      menu.classList.add('opacity-0', 'pointer-events-none');
      menu.classList.remove('opacity-100');
      hLines[0].style.transform = '';
      hLines[1].style.opacity   = '';
      hLines[2].style.transform = '';
      mLinks.forEach((el) => {
        el.style.opacity   = '0';
        el.style.transform = 'translateY(4px)';
      });
    }

    toggle.addEventListener('click', () => (open ? closeMenu() : openMenu()));
    mLinks.forEach((el) => el.addEventListener('click', closeMenu));

    // Close when viewport becomes ≥ 640px (sm breakpoint) — e.g. on rotation
    const mq = window.matchMedia('(min-width: 640px)');
    mq.addEventListener('change', (e) => { if (e.matches && open) closeMenu(); });
  }

  document.addEventListener('astro:page-load', initNav);
</script>
