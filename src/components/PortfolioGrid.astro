---
export interface Project {
  title:    string;
  category: string;
  /** Path relative to /public, e.g. "/images/projects/project-1.jpg" */
  image:    string;
  alt:      string;
  /** Optional link to a project page or external URL */
  href?:    string;
  /** Optional placeholder colour used when image is not yet available */
  placeholder?: string;
  /** SVG markup for the card icon */
  icon?:    string;
  /** Filter tag derived from icon */
  tag?:     string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

const fallbackGradients = [
  'linear-gradient(135deg, #3d2e20 0%, #6b4a2e 100%)',
  'linear-gradient(135deg, #1e2832 0%, #2e4055 100%)',
  'linear-gradient(135deg, #1e2820 0%, #2e4830 100%)',
  'linear-gradient(135deg, #2e2030 0%, #4a3050 100%)',
  'linear-gradient(135deg, #30221a 0%, #5a3828 100%)',
  'linear-gradient(135deg, #1a2430 0%, #283848 100%)',
];
---

<section
  id="work"
  class="pb-24 md:pb-32"
  aria-label="Portfolio"
>
  <!-- Section header -->
  <div class="flex items-center justify-between px-6 md:px-14 lg:px-20 mb-6 md:mb-8">
    <div class="flex items-center gap-3">
      <img src="/images/nutty.png" alt="" aria-hidden="true" class="h-8 w-auto" />
      <h2 class="font-serif text-xl md:text-3xl font-light tracking-[0.04em]">
        Selected Portfolio
      </h2>
    </div>
    <span
      class="text-[0.58rem] tracking-[0.22em] uppercase tabular-nums"
      style="color: var(--muted);"
    >
      {String(projects.length).padStart(2, '0')} Projects
    </span>
  </div>

  <!-- Filter bar -->
  <div class="flex items-center gap-3 px-6 md:px-14 lg:px-20 mb-6">
    <button class="pg-filter active" data-filter="all">
      <span class="pg-filter-label">All</span>
    </button>
    <button class="pg-filter" data-filter="vr">
      <span class="pg-filter-icon" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-4a2 2 0 0 1-1.6-.8l-1.6-2.13a1 1 0 0 0-1.6 0L9.6 17.2A2 2 0 0 1 8 18H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2z"/></svg>`} />
      <span class="pg-filter-label">VR</span>
    </button>
    <button class="pg-filter" data-filter="ar">
      <span class="pg-filter-icon" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="m3.794 11 .47-1.542H6.27L6.739 11H8L5.996 5.001H4.607L2.595 11zm1.503-4.852.734 2.426h-1.52l.734-2.426zm5.598-1.147H8.5V11h1.173V8.763h1.064L11.787 11h1.327L11.91 8.583C12.455 8.373 13 7.779 13 6.9c0-1.147-.773-1.9-2.105-1.9zm-1.222 2.87V5.933h1.05c.63 0 1.05.347 1.05.989 0 .633-.408.95-1.067.95z"/><path d="M14 3a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zM2 2a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z"/></svg>`} />
      <span class="pg-filter-label">AR</span>
    </button>
    <button class="pg-filter" data-filter="gamedev">
      <span class="pg-filter-icon" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M11.5 6.027a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0m-1.5 1.5a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1m2.5-.5a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0m-1.5 1.5a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1m-6.5-3h1v1h1v1h-1v1h-1v-1h-1v-1h1z"/><path d="M3.051 3.26a.5.5 0 0 1 .354-.613l1.932-.518a.5.5 0 0 1 .62.39c.655-.079 1.35-.117 2.043-.117.72 0 1.443.041 2.12.126a.5.5 0 0 1 .622-.399l1.932.518a.5.5 0 0 1 .306.729q.211.136.373.297c.408.408.78 1.05 1.095 1.772.32.733.599 1.591.805 2.466s.34 1.78.364 2.606c.024.816-.059 1.602-.328 2.21a1.42 1.42 0 0 1-1.445.83c-.636-.067-1.115-.394-1.513-.773-.245-.232-.496-.526-.739-.808-.126-.148-.25-.292-.368-.423-.728-.804-1.597-1.527-3.224-1.527s-2.496.723-3.224 1.527c-.119.131-.242.275-.368.423-.243.282-.494.575-.739.808-.398.38-.877.706-1.513.773a1.42 1.42 0 0 1-1.445-.83c-.27-.608-.352-1.395-.329-2.21.024-.826.16-1.73.365-2.606.206-.875.486-1.733.805-2.466.315-.722.687-1.364 1.094-1.772a2.3 2.3 0 0 1 .433-.335l-.028-.079zm2.036.412c-.877.185-1.469.443-1.733.708-.276.276-.587.783-.885 1.465a14 14 0 0 0-.748 2.295 12.4 12.4 0 0 0-.339 2.406c-.022.755.062 1.368.243 1.776a.42.42 0 0 0 .426.24c.327-.034.61-.199.929-.502.212-.202.4-.423.615-.674.133-.156.276-.323.44-.504C4.861 9.969 5.978 9.027 8 9.027s3.139.942 3.965 1.855c.164.181.307.348.44.504.214.251.403.472.615.674.318.303.601.468.929.503a.42.42 0 0 0 .426-.241c.18-.408.265-1.02.243-1.776a12.4 12.4 0 0 0-.339-2.406 14 14 0 0 0-.748-2.295c-.298-.682-.61-1.19-.885-1.465-.264-.265-.856-.523-1.733-.708-.85-.179-1.877-.27-2.913-.27s-2.063.091-2.913.27"/></svg>`} />
      <span class="pg-filter-label">Gamedev</span>
    </button>
    <button class="pg-filter" data-filter="web">
      <span class="pg-filter-icon" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m7.5-6.923c-.67.204-1.335.82-1.887 1.855A8 8 0 0 0 5.145 4H7.5zM4.09 4a9.3 9.3 0 0 1 .64-1.539 7 7 0 0 1 .597-.933A7.03 7.03 0 0 0 2.255 4zm-.582 3.5c.03-.877.138-1.718.312-2.5H1.674a7 7 0 0 0-.656 2.5zM4.847 5a12.5 12.5 0 0 0-.338 2.5H7.5V5zM8.5 5v2.5h2.99a12.5 12.5 0 0 0-.337-2.5zM4.51 8.5a12.5 12.5 0 0 0 .337 2.5H7.5V8.5zm3.99 0V11h2.653c.187-.765.306-1.608.338-2.5zM5.145 12q.208.58.468 1.068c.552 1.035 1.218 1.65 1.887 1.855V12zm.182 2.472a7 7 0 0 1-.597-.933A9.3 9.3 0 0 1 4.09 12H2.255a7 7 0 0 0 3.072 2.472M3.82 11a13.7 13.7 0 0 1-.312-2.5h-2.49c.062.89.291 1.733.656 2.5zm6.853 3.472A7 7 0 0 0 13.745 12H11.91a9.3 9.3 0 0 1-.64 1.539 7 7 0 0 1-.597.933M8.5 12v2.923c.67-.204 1.335-.82 1.887-1.855q.26-.487.468-1.068zm3.68-1h2.146c.365-.767.594-1.61.656-2.5h-2.49a13.7 13.7 0 0 1-.312 2.5m2.802-3.5a7 7 0 0 0-.656-2.5H12.18c.174.782.282 1.623.312 2.5zM11.27 2.461c.247.464.462.98.64 1.539h1.835a7 7 0 0 0-3.072-2.472c.218.284.418.598.597.933M10.855 4a8 8 0 0 0-.468-1.068C9.835 1.897 9.17 1.282 8.5 1.077V4z"/></svg>`} />
      <span class="pg-filter-label">Web</span>
    </button>
  </div>

  <!-- Responsive square grid -->
  <!--
    Columns:
    Mobile (< 640px):  1 column
    sm    (≥ 640px):   2 columns
    lg    (≥ 1024px):  3 columns
    xl    (≥ 1280px):  3 columns (can bump to 4 if you have more projects)
  -->
  <ul
    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-[var(--gap)]
           px-[var(--gap)] list-none"
    role="list"
  >
    {projects.map((project, i) => {
      const Tag = project.href ? 'a' : 'div';
      const gradient = project.placeholder ?? fallbackGradients[i % fallbackGradients.length];

      return (
        <li class="pg-card-item" data-tag={project.tag ?? 'other'}>
          <Tag
            {...(project.href ? { href: project.href } : {})}
            class="card focus-visible:outline-accent"
            aria-label={project.href ? `View project: ${project.title}` : project.title}
          >
            <!-- Image or gradient placeholder -->
            <div
              class="card-bg"
              style={`background: ${gradient};`}
            >
              {/* Real image layered on top of gradient — if image is missing the gradient shows */}
              <img
                src={project.image}
                alt={project.alt}
                loading="eager"
                decoding="async"
                class="card-img w-full h-full object-cover object-center"
                onerror="this.style.display='none'"
              />
            </div>

            <div class="card-overlay" aria-hidden="true"></div>

            <div class="card-info">
              <p class="card-title">{project.title}</p>
              <p class="card-category">{project.category}</p>
            </div>

            {project.icon && (
              <div class="card-icon" aria-hidden="true" set:html={project.icon} />
            )}
          </Tag>
        </li>
      );
    })}
  </ul>
</section>

<style>
  .pg-filter {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--border);
    background: transparent;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
    color: var(--muted);
  }
  .pg-filter-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .pg-filter-icon {
    display: flex;
    align-items: center;
  }
  .pg-filter:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .pg-filter.active {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--paper);
  }
  .pg-card-item {
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .pg-card-item.hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.97);
  }
</style>

<script>
  function resetCardImages() {
    document.querySelectorAll<HTMLImageElement>('.card-img').forEach((img) => {
      if (img.style.display === 'none') {
        img.style.display = '';
        // Re-trigger load by bouncing the src
        const src = img.getAttribute('src') ?? '';
        img.setAttribute('src', '');
        img.setAttribute('src', src);
      }
    });
  }

  function initFilters() {
    const buttons = Array.from(document.querySelectorAll<HTMLElement>('.pg-filter'));
    const items   = Array.from(document.querySelectorAll<HTMLElement>('.pg-card-item'));
    if (!buttons.length) return;

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? 'all';

        // Update active button
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Show / hide cards
        items.forEach((item) => {
          const tag = item.dataset.tag ?? 'other';
          const visible = filter === 'all' || tag === filter;
          item.classList.toggle('hidden', !visible);
        });
      });
    });
  }

  // Runs on first load and after every View Transition
  document.addEventListener('astro:page-load', () => {
    resetCardImages();
    initFilters();
  });
</script>
