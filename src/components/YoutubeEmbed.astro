---
/**
 * YoutubeEmbed — a privacy-first, performant YouTube embed.
 *
 * Shows a thumbnail + play button facade. The real iframe is only injected
 * when the user clicks — no YouTube JS or tracking on page load.
 *
 * Modes:
 *   default    → thumbnail + play button facade, click to load iframe
 *   background → silent autoplay loop (no controls), useful for hero sections
 *
 * Usage — standard embed:
 *   <YoutubeEmbed id="dQw4w9WgXcQ" title="My video" />
 *
 * Usage — background / hero video:
 *   <YoutubeEmbed id="dQw4w9WgXcQ" mode="background" />
 *
 * Getting the YouTube video ID:
 *   From URL https://www.youtube.com/watch?v=dQw4w9WgXcQ → id is "dQw4w9WgXcQ"
 *
 * Thumbnail grades (best → fallback):
 *   maxresdefault → hqdefault (YouTube serves these directly, no API needed)
 */

interface Props {
  /** YouTube video ID */
  id: string;
  /** Accessible title of the video */
  title?: string;
  /**
   * 'default'    — shows a play-button facade; loads iframe on click
   * 'background' — silent autoplay loop with no UI chrome
   */
  mode?: 'default' | 'background';
  /**
   * Custom poster/thumbnail image path.
   * If omitted, falls back to YouTube's own maxresdefault thumbnail.
   */
  thumbnail?: string;
  /** Aspect ratio string, e.g. "16/9" or "4/3" */
  aspectRatio?: string;
  /** Corner rounding */
  rounded?: boolean;
  /** Extra CSS classes on the outer wrapper */
  class?: string;
  /** Caption shown below the embed */
  caption?: string;
  /** Start time in seconds */
  startAt?: number;
}

const {
  id,
  title       = 'Video',
  mode        = 'default',
  thumbnail,
  aspectRatio = '16/9',
  rounded     = false,
  class: cls  = '',
  caption,
  startAt     = 0,
} = Astro.props;

const uid = `yt-${id}-${Math.random().toString(36).slice(2, 6)}`;

const resolvedThumbnail = thumbnail;

// Build iframe src
const params = new URLSearchParams({
  autoplay:       '1',
  rel:            '0',   // no related videos
  modestbranding: '1',
  ...(mode === 'background' ? {
    mute:     '1',
    loop:     '1',
    controls: '0',
    playlist: id,        // required for loop to work
  } : {}),
  ...(startAt > 0 ? { start: String(startAt) } : {}),
});

const iframeSrc = `https://www.youtube-nocookie.com/embed/${id}?${params}`;
---

<figure class:list={['yt-embed-wrap', cls]} style="margin:0;">
  <div
    id={uid}
    class="yt-embed-container"
    style={[
      `position:relative;`,
      `aspect-ratio:${aspectRatio};`,
      `background:#0a0806;`,
      `overflow:hidden;`,
      rounded ? 'border-radius:8px;' : '',
    ].join('')}
  >

    {mode === 'background' ? (
      /* ── Background / hero mode ─────────────────────────── */
      <>
        {resolvedThumbnail && (
          <img
            src={resolvedThumbnail}
            alt=""
            aria-hidden="true"
            loading="lazy"
            decoding="async"
            style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:1;"
          />
        )}
        <iframe
          src={iframeSrc}
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          title={title}
          loading="lazy"
          style="position:absolute;inset:0;width:100%;height:100%;border:0;z-index:2;"
        ></iframe>
      </>
    ) : (
      /* ── Default / facade mode ──────────────────────────── */
      <>
        {/* Thumbnail or gradient placeholder */}
        {resolvedThumbnail ? (
          <img
            src={resolvedThumbnail}
            alt={title}
            loading="lazy"
            decoding="async"
            class="yt-thumb"
            style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:1;transition:transform 0.5s ease;"
          />
        ) : (
          <div
            aria-hidden="true"
            style="position:absolute;inset:0;background:linear-gradient(135deg,#2c2720,#1a1410);z-index:1;"
          ></div>
        )}

        {/* Dark overlay */}
        <div
          aria-hidden="true"
          class="yt-overlay"
          style="position:absolute;inset:0;background:rgba(10,8,6,0.32);z-index:2;transition:background 0.3s;"
        ></div>

        {/* Play button */}
        <button
          class="yt-play-btn"
          aria-label={`Play ${title}`}
          style={[
            'position:absolute;inset:0;width:100%;height:100%;',
            'display:flex;align-items:center;justify-content:center;',
            'background:transparent;border:none;cursor:pointer;z-index:3;',
          ].join('')}
        >
          <span class="yt-play-icon" aria-hidden="true">
            <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="36" cy="36" r="35.5" fill="rgba(10,8,6,0.55)" stroke="rgba(245,242,236,0.3)"/>
              <path d="M28 24l22 12-22 12V24z" fill="#FFFFFF"/>
            </svg>
          </span>
        </button>

        {/* Title badge */}
        <div
          class="yt-title-badge"
          aria-hidden="true"
          style={[
            'position:absolute;bottom:1rem;left:1rem;z-index:3;',
            'font-family:"DM Mono",monospace;font-size:0.6rem;',
            'letter-spacing:0.2em;text-transform:uppercase;',
            'color:rgba(255,255,255,0.75);',
            'transition:opacity 0.3s;',
          ].join('')}
        >
          {title}
        </div>
      </>
    )}
  </div>

  {caption && (
    <figcaption
      style="margin-top:0.6rem;font-size:0.65rem;letter-spacing:0.12em;color:var(--muted, #8a8278);"
    >
      {caption}
    </figcaption>
  )}
</figure>

<style>
  .yt-play-btn:hover .yt-thumb {
    transform: scale(1.03);
  }
  .yt-play-btn:hover .yt-play-icon circle {
    fill: rgba(193,127,61,0.7);
    stroke: rgba(193,127,61,0.6);
  }
  .yt-play-btn:hover ~ .yt-overlay {
    background: rgba(10,8,6,0.18);
  }
  .yt-play-btn:focus-visible {
    outline: 2px solid #c17f3d;
    outline-offset: 4px;
  }
  .yt-play-btn:hover ~ .yt-title-badge {
    opacity: 0;
  }
</style>

{mode === 'default' && (
  <script define:vars={{ uid, iframeSrc, title }}>
    const container = document.getElementById(uid);
    if (!container) return;

    const btn = container.querySelector('.yt-play-btn');
    if (!btn) return;

    btn.addEventListener('click', () => {
      container.innerHTML = `
        <iframe
          src="${iframeSrc}"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          title="${title}"
          style="position:absolute;inset:0;width:100%;height:100%;border:0;"
        ></iframe>
      `;
    });
  </script>
)}
