---
import Layout        from '../layouts/Layout.astro';
import Nav           from '../components/Nav.astro';
import Cover         from '../components/Cover.astro';
import About         from '../components/About.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import Footer        from '../components/Footer.astro';
// import BlueSkyFeed  from '../components/BlueSkyFeed.astro';
import { projects }  from '../data/projects';
import type { FooterLink } from '../components/Footer.astro';

// Map central data → PortfolioGrid shape.
// Cards now link to each project's own page.
const gridProjects = projects.map((p) => ({
  title:       p.title,
  category:    p.category,
  image:       p.cover,
  alt:         p.coverAlt,
  placeholder: p.placeholder,
  href:        `/projects/${p.slug}`,
  icon:        p.icon,
}));

const footerLinks: FooterLink[] = [
  { label: 'Email',    href: 'mailto:info@tntc.it'                  },
  { label: 'Youtube', href: 'http://youtube.com/tntcproject'      },
  { label: 'Patreon', href: 'https://www.patreon.com/c/tntcproject'     },
  { label: 'LinkedIn', href: 'https://it.linkedin.com/company/tntc'  },
  { label: 'Bluesky', href: 'https://bsky.app/profile/tntcproject.bsky.social'  },
  { label: 'GitHub',   href: 'https://github.com/ToughNutToCrack'        },
];
---

<Layout
  title="TNTC Studio"
  description="Meet TNTC Studio and craft real-time experiences with us!"
>
  <Nav />

  <main>
    <Cover
      tagline="Meet TNTC Studio"
      videos={[
        '/videos/hero1r.mp4',
        '/videos/hero5r.mp4',
        '/videos/hero2r.mp4',
        '/videos/hero0r.mp4',
        '/videos/hero3r.mp4',
        '/videos/hero4r.mp4',
      ]}
      texts={[
        { lines: ['Videogames', '<em>design &amp;</em>', 'development'] },
        { lines: ['Immersive', '<em>XR</em>', 'experiences'] },
        { lines: ['Advanced', '<em>technical art</em>', 'production'] },
        { lines: ['Custom', '<em>tools</em>', 'creation'] },
        { lines: ['3D assets', '<em>modeling &amp;</em>', 'authoring'] },
        { lines: ['Procedural', '<em>content</em>', 'generation'] }
      ]}
    />

    <About
      headline="TNTC specializes in gamedev, XR, and custom tools."
      body={`We are a team of <span style="color:var(--accent)">experienced developers</span> with a long presence in the industry. Over the years, we have worked across every stage of development, completing <span style="color:var(--accent)">real-time</span> projects in full or focusing on specific phases, always learning and refining our approach. We’ve collaborated with clients of every scale, from startups to major brands. Thanks to our online work and contributions to the <span style="color:var(--accent)">game development</span> community, we are also part of the Unity Insider program.`}
      body2={`Alongside all of this, we create our own <span style="color:var(--accent)">original content</span>, including <span style="color:var(--accent)">games</span>, <span style="color:var(--accent)">experiments</span>, and <span style="color:var(--accent)">interactive experiences</span>.`}
      images={[
        '/images/tntc.webp',
        '/images/tntc3.jpg',
        '/images/tntc2.jpg',
        '/images/tntc4.jpg',
      ]}
    />

    <PortfolioGrid projects={gridProjects} />
    <!-- <BlueSkyFeed handle="tntcproject.bsky.social" limit={6} /> -->
  </main>

  <Footer name="TNTC Studio" links={footerLinks} />
</Layout>
