---
import Layout        from '../layouts/Layout.astro';
import Nav           from '../components/Nav.astro';
import Cover         from '../components/Cover.astro';
import About         from '../components/About.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import Footer        from '../components/Footer.astro';
import { projects }  from '../data/projects';
import type { FooterLink } from '../components/Footer.astro';

// Map central data → PortfolioGrid shape.
// Cards now link to each project's own page.
const gridProjects = projects.map((p) => ({
  title:       p.title,
  category:    p.category,
  image:       p.cover,
  alt:         p.coverAlt,
  placeholder: p.placeholder,
  href:        `/projects/${p.slug}`,
  icon:        p.icon,
}));

const footerLinks: FooterLink[] = [
  { label: 'Email',    href: 'mailto:info@tntc.it'                  },
  { label: 'Youtube', href: 'http://youtube.com/tntcproject'      },
  { label: 'Patreon', href: 'https://www.patreon.com/c/tntcproject'     },
  { label: 'LinkedIn', href: 'https://it.linkedin.com/company/tntc'  },
  { label: 'GitHub',   href: 'https://github.com/ToughNutToCrack'        },
];
---

<Layout
  title="TNTC Studio"
  description="Meet TNTC Studio and craft realtime experiences with us!"
>
  <Nav />

  <main>
    <Cover
      tagline="Meet TNTC Studio"
      videos={[
        '/videos/hero1r.mp4',
        '/videos/hero5r.mp4',
        '/videos/hero2r.mp4',
        '/videos/hero0r.mp4',
        '/videos/hero3r.mp4',
        '/videos/hero4r.mp4',
      ]}
    />

    <About
      headline="TNTC specializes in gamedev, XR, and custom tools."
      body="We are a team of experienced developers with a long presence in the industry. Over the years, we have worked across every stage of development, completing real-time projects in full or focusing on specific phases, always learning and refining our approach. We’ve collaborated with clients of every scale, from startups to major brands. Thanks to our online work and contributions to the game development community, we are also part of the Unity Insider program.  Alongside all of this, we create our own original content, including games, experiments, and interactive experiences."
    />

    <PortfolioGrid projects={gridProjects} />
  </main>

  <Footer name="TNTC Studio" links={footerLinks} />
</Layout>
